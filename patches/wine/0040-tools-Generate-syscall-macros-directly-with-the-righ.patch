From 63e3f6a723a053dce4b9dacc40f170738fad689b Mon Sep 17 00:00:00 2001
From: Alexandre Julliard <julliard@winehq.org>
Date: Tue, 29 Apr 2025 18:00:58 +0200
Subject: [PATCH 40/63] tools: Generate syscall macros directly with the right
 offset.

---
 dlls/win32u/main.c   |  6 +++---
 tools/make_specfiles | 17 +++++++++--------
 2 files changed, 12 insertions(+), 11 deletions(-)

diff --git a/dlls/win32u/main.c b/dlls/win32u/main.c
index 1548f3e773a..551d8f3cf07 100644
--- a/dlls/win32u/main.c
+++ b/dlls/win32u/main.c
@@ -39,7 +39,7 @@ void *__wine_syscall_dispatcher = NULL;
 #ifdef __arm64ec__
 enum syscall_ids
 {
-#define SYSCALL_ENTRY(id,name,args) __id_##name = id + 0x1000,
+#define SYSCALL_ENTRY(id,name,args) __id_##name = id,
 ALL_SYSCALLS64
 #undef SYSCALL_ENTRY
 };
@@ -2369,10 +2369,10 @@ BOOL SYSCALL_API __wine_get_icm_profile( HDC hdc, BOOL allow_default, DWORD *siz
 #else /*  __arm64ec__ */
 
 #ifdef _WIN64
-#define SYSCALL_ENTRY(id,name,args) __ASM_SYSCALL_FUNC( id + 0x1000, name )
+#define SYSCALL_ENTRY(id,name,args) __ASM_SYSCALL_FUNC( id, name )
 ALL_SYSCALLS64
 #else
-#define SYSCALL_ENTRY(id,name,args) __ASM_SYSCALL_FUNC( id + 0x1000, name, args )
+#define SYSCALL_ENTRY(id,name,args) __ASM_SYSCALL_FUNC( id, name, args )
 DEFINE_SYSCALL_HELPER32()
 ALL_SYSCALLS32
 #endif
diff --git a/tools/make_specfiles b/tools/make_specfiles
index 0509d41d5c1..34b35642a2b 100755
--- a/tools/make_specfiles
+++ b/tools/make_specfiles
@@ -327,15 +327,16 @@ sub get_args_size($)
     return ($ret32, $ret64);
 }
 
-sub get_syscalls_str(@)
+sub get_syscalls_str($@)
 {
+    my $base = shift;
     my @syscalls = sort { $a->[0] cmp $b->[0] } @_;
 
     my $ret = "";
     for (my $i = 0; $i < @syscalls; $i++)
     {
         my ($name, $args) = @{$syscalls[$i]};
-        $ret .= sprintf " \\\n    SYSCALL_ENTRY( 0x%04x, %s, %u )", $i, $name, $args;
+        $ret .= sprintf " \\\n    SYSCALL_ENTRY( 0x%04x, %s, %u )", $base + $i, $name, $args;
     }
     return $ret . "\n";
 }
@@ -361,15 +362,15 @@ sub read_syscalls($)
     return (\@syscalls32, \@syscalls64);
 }
 
-sub update_syscalls($$)
+sub update_syscalls($$$)
 {
-    my ($spec, $file) = @_;
+    my ($spec, $file, $base) = @_;
     my ($syscalls32, $syscalls64) = read_syscalls( $spec );
 
     output_file( $file,
                  "/* Automatically generated by tools/make_specfiles */\n" .
-                 "\n#define ALL_SYSCALLS32" . get_syscalls_str( @{$syscalls32} ) .
-                 "\n#define ALL_SYSCALLS64" . get_syscalls_str( @{$syscalls64} ));
+                 "\n#define ALL_SYSCALLS32" . get_syscalls_str( $base, @{$syscalls32} ) .
+                 "\n#define ALL_SYSCALLS64" . get_syscalls_str( $base, @{$syscalls64} ));
 }
 
 sub sync_spec_files(@)
@@ -385,5 +386,5 @@ foreach my $group (@dll_groups)
     sync_spec_files( @{$group} );
 }
 
-update_syscalls( "ntdll", "dlls/ntdll/ntsyscalls.h" );
-update_syscalls( "win32u", "dlls/win32u/win32syscalls.h" );
+update_syscalls( "ntdll", "dlls/ntdll/ntsyscalls.h", 0 );
+update_syscalls( "win32u", "dlls/win32u/win32syscalls.h", 0x1000 );
-- 
2.53.0

