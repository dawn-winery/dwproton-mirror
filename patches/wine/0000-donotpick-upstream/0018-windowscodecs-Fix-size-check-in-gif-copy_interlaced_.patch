From 7fa625d69a6bd67353cd807f596e3ecaa57c2e35 Mon Sep 17 00:00:00 2001
From: Esme Povirk <esme@codeweavers.com>
Date: Thu, 19 Feb 2026 20:18:26 +0000
Subject: [PATCH 18/63] windowscodecs: Fix size check in gif
 copy_interlaced_pixels.

Wine-Bug: https://bugs.winehq.org/show_bug.cgi?id=59428
---
 dlls/windowscodecs/gifformat.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/dlls/windowscodecs/gifformat.c b/dlls/windowscodecs/gifformat.c
index bdd6ccb4ef6..79fa4b347ae 100644
--- a/dlls/windowscodecs/gifformat.c
+++ b/dlls/windowscodecs/gifformat.c
@@ -607,7 +607,7 @@ static HRESULT copy_interlaced_pixels(const BYTE *srcbuffer,
     if (dststride < rc->Width)
         return E_INVALIDARG;
 
-    if ((dststride * rc->Height) > dstbuffersize)
+    if ((dststride * (rc->Height - 1)) + rc->Width > dstbuffersize)
         return E_INVALIDARG;
 
     row_offset = rc->X;
-- 
2.53.0

