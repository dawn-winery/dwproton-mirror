From f6059327d918dc999d76c5d8b5a4be0cdb6dad46 Mon Sep 17 00:00:00 2001
From: Zhiyi Zhang <zzhang@codeweavers.com>
Date: Sun, 1 Feb 2026 10:42:10 +0800
Subject: [PATCH 08/63] d2d1: Return S_OK for d2d_device_context_Flush().

React Native applications depend on this.

Wine-Bug: http://bugs.winehq.org/show_bug.cgi?id=50814
---
 dlls/d2d1/device.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/dlls/d2d1/device.c b/dlls/d2d1/device.c
index c34850f5a2e..33f71876d1f 100644
--- a/dlls/d2d1/device.c
+++ b/dlls/d2d1/device.c
@@ -1875,7 +1875,7 @@ static HRESULT STDMETHODCALLTYPE d2d_device_context_Flush(ID2D1DeviceContext6 *i
     if (context->ops && context->ops->device_context_present)
         context->ops->device_context_present(context->outer_unknown);
 
-    return E_NOTIMPL;
+    return S_OK;
 }
 
 static void STDMETHODCALLTYPE d2d_device_context_SaveDrawingState(ID2D1DeviceContext6 *iface,
-- 
2.53.0

