+      = dxvk::high_resolution_clock::now();
+
+    std::string m_gpuP50;
+    std::string m_gpuP75;
+    std::string m_gpuP95;
+    std::string m_gpuP99;
+
+    std::string m_presentP50;
+    std::string m_presentP75;
+    std::string m_presentP95;
+    std::string m_presentP99;
+
+  };
