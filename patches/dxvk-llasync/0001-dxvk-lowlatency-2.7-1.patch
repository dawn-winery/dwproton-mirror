From 17eec1c550e54d5be39eb66a5d3aa4d665025991 Mon Sep 17 00:00:00 2001
From: netborg <137700136+netborg-afps@users.noreply.github.com>
Date: Fri, 23 Jan 2026 13:23:45 +0100
Subject: [PATCH 59/61] [dxvk] Improve robustness to stutters

Cap the amount of time we wait until starting a frame. This matches how we did it for pre-2.7.1 versions and makes the pacing more robust to unexpected events.
---
 src/dxvk/framepacer/dxvk_framepacer_mode_low_latency.h | 5 ++++-
 src/dxvk/framepacer/dxvk_gpu_progress.h                | 5 ++++-
 2 files changed, 8 insertions(+), 2 deletions(-)

diff --git a/src/dxvk/framepacer/dxvk_framepacer_mode_low_latency.h b/src/dxvk/framepacer/dxvk_framepacer_mode_low_latency.h
index 8419cb5b..e4a291bc 100644
--- a/src/dxvk/framepacer/dxvk_framepacer_mode_low_latency.h
+++ b/src/dxvk/framepacer/dxvk_framepacer_mode_low_latency.h
@@ -116,7 +116,10 @@ namespace dxvk {
       time_point lastFrameFinishPrediction;
 
       if (targetGpuTime < props.optimizedGpuTime) {
-        m_gpuProgress.waitUntil( frameId-1, targetGpuTime, props.cpuUntilGpuStart );
+        int32_t maxDelay = std::max( m_fpsLimitFrametime.load(), 20000 );
+        time_point maxSleep = m->start + microseconds(maxDelay);
+
+        m_gpuProgress.waitUntil( frameId-1, targetGpuTime, props.cpuUntilGpuStart, maxSleep );
         lastFrameFinishPrediction = high_resolution_clock::now()
           + microseconds(props.optimizedGpuTime - targetGpuTime);
       }
diff --git a/src/dxvk/framepacer/dxvk_gpu_progress.h b/src/dxvk/framepacer/dxvk_gpu_progress.h
index 0a646e05..9fe23bfd 100644
--- a/src/dxvk/framepacer/dxvk_gpu_progress.h
+++ b/src/dxvk/framepacer/dxvk_gpu_progress.h
@@ -102,7 +102,7 @@ namespace dxvk {
     }
 
 
-    void waitUntil( uint64_t frameId, int32_t targetGpuRuntime, int32_t cpuUntilGpuStart ) const {
+    void waitUntil( uint64_t frameId, int32_t targetGpuRuntime, int32_t cpuUntilGpuStart, time_point maxSleep ) const {
       // GPU progress is measured as if the submits would be processed as late as possible
       // on the GPU while assuming the frame to be minimum latency since gpuStart.
       // This is necessary for this to work reliably accross games.
@@ -120,6 +120,7 @@ namespace dxvk {
       int32_t sleepDelay = std::max( 0, sleepUntil - totalTime );
 
       Sleep::TimePoint t = now + microseconds(sleepDelay);
+      t = std::min(t, maxSleep);
       Sleep::sleepUntil( now, t );
 
       // For the remainder of the frame we check the progress by polling.
@@ -133,6 +134,8 @@ namespace dxvk {
           break;
         if (data->isFinished || data->reachedMaxSubmits)
           break;
+        if (high_resolution_clock::now() > maxSleep)
+          break;
         pause();
 
       }
