+        const SyncProps& props = m_props[ (frameId-i) % m_props.size() ];
+        totalCpuTime += props.cpuUntilGpuStart;
       }
 
       int32_t avgCpuTime = totalCpuTime / (numLoop-1);
-      const LatencyMarkers* m = m_latencyMarkersStorage->getConstMarkers(frameId);
