diff --git a/src/util/config/config.cpp.orig b/src/util/config/config.cpp.orig
new file mode 100644
index 00000000..fa67a940
--- /dev/null
+++ b/src/util/config/config.cpp.orig
@@ -0,0 +1,1722 @@
