-    if (size > threshold)
-      return false;
-
-    // If the buffer is used for transform feedback in any way, we have to stop
-    // the render pass anyway, but we can at least avoid an extra barrier.
-    if (unlikely(m_flags.test(DxvkContextFlag::GpXfbActive))) {
