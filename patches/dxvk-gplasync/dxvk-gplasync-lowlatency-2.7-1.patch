-  bool DxvkContext::checkBufferViewBarrier(
-    const Rc<DxvkBufferView>&       bufferView,
-          VkAccessFlags             access,
-          DxvkAccessOp              accessOp) {
-    return checkResourceBarrier<BindPoint>([this, &bufferView, accessOp] (DxvkAccess access) {
