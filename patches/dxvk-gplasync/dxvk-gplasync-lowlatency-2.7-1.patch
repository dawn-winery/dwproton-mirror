-    // Ignore large buffers to keep memory overhead in check. Use a higher
-    // threshold when a render pass is active to avoid interrupting it.
-    VkDeviceSize threshold = !m_flags.test(DxvkContextFlag::GpRenderPassBound)
-      ? MaxDiscardSizeInRp
-      : MaxDiscardSize;
