-  bool Config::parseOptionValue(
-    const std::string&  value,
-          int32_t&      result) {
-    if (value.size() == 0)
-      return false;
-
-    // Parse sign, don't allow '+'
-    int32_t sign = 1;
-    size_t start = 0;
-
-    if (value[0] == '-') {
-      sign = -1;
-      start = 1;
-    }
-
-    // Parse absolute number
-    int32_t intval = 0;
-
-    for (size_t i = start; i < value.size(); i++) {
-      if (value[i] < '0' || value[i] > '9')
-        return false;
-
-      intval *= 10;
-      intval += value[i] - '0';
-    }
-
-    // Apply sign and return
-    result = sign * intval;
-    return true;
-  }
