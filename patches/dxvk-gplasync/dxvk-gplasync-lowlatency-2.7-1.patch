-      if (aspect & VK_IMAGE_ASPECT_COLOR_BIT) {
-        uint32_t colorIndex = m_state.om.framebufferInfo.getColorAttachmentIndex(attachmentIndex);
-        m_state.om.attachmentMask.trackColorWrite(colorIndex);
