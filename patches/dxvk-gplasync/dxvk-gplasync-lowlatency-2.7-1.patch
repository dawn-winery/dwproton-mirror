diff --git a/src/dxvk/dxvk_context.cpp.orig b/src/dxvk/dxvk_context.cpp.orig
new file mode 100644
index 00000000..4be55ab8
--- /dev/null
+++ b/src/dxvk/dxvk_context.cpp.orig
@@ -0,0 +1,9408 @@
+#include <algorithm>
+#include <cmath>
+#include <cstring>
+#include <map>
+#include <vector>
+#include <utility>
+
+#include "dxvk_device.h"
+#include "dxvk_context.h"
