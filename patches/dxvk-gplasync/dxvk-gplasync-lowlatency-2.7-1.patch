-    // Guarantee that we can render to or sample the images
-    DxvkImageUsageInfo dstUsage = { };
-    dstUsage.usage = VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT;
-    dstUsage.viewFormatCount = 1;
-    dstUsage.viewFormats = &viewFormats.dstFormat;
