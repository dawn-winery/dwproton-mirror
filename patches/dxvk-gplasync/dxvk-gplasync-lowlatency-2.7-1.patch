-  void DxvkPipelineWorkers::stopWorkers() {
-    { std::unique_lock lock(m_lock);
-
-      if (!m_workersRunning)
-        return;
-
-      m_workersRunning = false;
-
-      for (uint32_t i = 0; i < m_buckets.size(); i++)
-        m_buckets[i].cond.notify_all();
