-    } else {
-      if (m_barrierControl.test(DxvkBarrierControl::GraphicsAllowReadWriteOverlap))
-        label = "Relaxed sync";
-    }
-
-    if (label) {
-      pushDebugRegion(vk::makeLabel(0x9bded9, label),
-        util::DxvkDebugLabelType::InternalBarrierControl);
-    }
