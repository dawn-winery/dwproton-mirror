-      m_cmd->cmdBeginDebugUtilsLabel(DxvkCmdBuffer::ExecBuffer,
-        vk::makeLabel(0xf0dcdc, str::format("Copy image (",
-          dstName ? dstName : "unknown", ", ",
-          srcName ? srcName : "unknown", ")").c_str()));
